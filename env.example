# ════════════════════════════════════════
#  SENIORSHIELD — Environment Variables
#  Salin file ini menjadi .env
#  cp .env.example .env
# ════════════════════════════════════════

# Port HTTP server (dashboard & API)
PORT=3000

# Port WebSocket server (real-time)
WS_PORT=3001

# API Key — WAJIB diganti di production!
# Generate key acak: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=seniorshield-secret-key

# (Opsional) Whitelist IP yang boleh mengakses endpoint /api/sms/incoming
# Kosongkan jika tidak ingin membatasi IP
ALLOWED_IP=
